# Dev image: runs `vite` with hot-reload. Production image is added when we
# need a deploy target (would build static assets and serve via nginx).

FROM node:22-alpine

ENV PNPM_HOME=/pnpm \
    PATH=/pnpm:$PATH \
    CI=true

RUN corepack enable && corepack prepare pnpm@11.0.9 --activate

WORKDIR /repo

# Workspace manifests first — best cache layer. The source itself comes from a
# bind mount in docker-compose so the dev container hot-reloads on edits.
COPY pnpm-workspace.yaml package.json ./
COPY apps/web/package.json ./apps/web/
COPY packages/shared-types/package.json ./packages/shared-types/

RUN --mount=type=cache,id=pnpm,target=/pnpm/store \
    pnpm install --filter web... --frozen-lockfile=false

WORKDIR /repo/apps/web

EXPOSE 5173

# --host 0.0.0.0 makes Vite reachable from the host machine.
CMD ["pnpm", "exec", "vite", "--host", "0.0.0.0", "--port", "5173"]
